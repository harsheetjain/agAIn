# Copy to `.env.local` and fill in as you wire up integrations.
# Vite only exposes variables prefixed with VITE_ to client code.
# NEVER put secret keys in a VITE_-prefixed var — proxy them through a server.

# Optional: LLM provider for an LlmDjBrain (see AGENTS.md → "Swap in an LLM brain").
# VITE_LLM_PROVIDER=openai

# Server-side only (do NOT prefix with VITE_): keep real secrets off the client.
# LLM_API_KEY=
